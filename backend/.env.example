# Backend Environment Variables
# Copy this file to .env and fill in the values
# .env is gitignored — it will NOT be pushed to the repo

# Supabase project (get from Supabase dashboard)
# Use the DEV project ID for local development
SUPABASE_PROJECT_ID=<your-supabase-project-id>
SUPABASE_REGION=ap-northeast-2

# Database (Supabase → Settings → Database → Connection Pooling)
DB_PASSWORD=<your-supabase-db-password>

# Django
SECRET_KEY=<generate-a-random-secret-key>
DEBUG=True

# Supabase Storage S3 (Supabase → Settings → Storage → S3 Connection)
AWS_ACCESS_KEY_ID=<your-s3-access-key>
AWS_SECRET_ACCESS_KEY=<your-s3-secret-key>

# Google Maps Geocoding
GOOGLE_MAPS_API_KEY=<your-google-maps-api-key>

# Email (Gmail SMTP — use App Password, not your real password)
EMAIL_HOST_USER=<your-email@gmail.com>
EMAIL_HOST_PASSWORD=<your-gmail-app-password>
